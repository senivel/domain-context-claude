---
interface Props {
  chart: string;
}

const { chart } = Astro.props;
const id = `mermaid-${Math.random().toString(36).slice(2, 9)}`;
---

<div class="mermaid-wrapper" id={id}>
  <pre class="mermaid">{chart}</pre>
</div>

<script>
  import mermaid from 'mermaid';

  function getTheme() {
    return document.documentElement.dataset.theme === 'light' ? 'default' : 'dark';
  }

  mermaid.initialize({
    startOnLoad: false,
    theme: getTheme(),
  });

  async function renderAll() {
    mermaid.initialize({ startOnLoad: false, theme: getTheme() });
    const elements = document.querySelectorAll('pre.mermaid');
    for (const el of elements) {
      // Store original source on first encounter
      const src = el.getAttribute('data-mermaid-src') || el.textContent || '';
      if (!el.getAttribute('data-mermaid-src')) {
        el.setAttribute('data-mermaid-src', src);
      }
      el.removeAttribute('data-processed');
      // Reset to original source text for re-render
      el.textContent = el.getAttribute('data-mermaid-src') || '';
    }
    await mermaid.run({ nodes: elements as unknown as ArrayLike<HTMLElement> });
  }

  // Initial render
  renderAll();

  // Re-render on theme change
  const observer = new MutationObserver((mutations) => {
    for (const mutation of mutations) {
      if (mutation.attributeName === 'data-theme') {
        renderAll();
      }
    }
  });
  observer.observe(document.documentElement, { attributes: true });
</script>

<style>
  .mermaid-wrapper {
    margin: 1rem 0;
    overflow-x: auto;
  }

  .mermaid-wrapper pre.mermaid {
    background: transparent;
    border: none;
    padding: 0;
    text-align: center;
  }
</style>
